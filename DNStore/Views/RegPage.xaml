<Page x:Class="DeezFiles.RegPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#212121"
      Title="Registration Page"
      UseLayoutRounding="True"
      TextOptions.TextFormattingMode="Display">

    <Page.Resources>
        <Style x:Key="AuthInputStyle"
                TargetType="TextBox">
            <Setter Property="Height"
                    Value="40"/>
            <Setter Property="Padding"
                    Value="12,8"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="Medium"/>
            <Setter Property="Background"
                    Value="#2f2f2f"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="CaretBrush"
                    Value="White"/>
            <Setter Property="SelectionBrush"
                    Value="#c9a9ff"/>
            <Setter Property="BorderBrush"
                    Value="#444444"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="0"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Foreground="{TemplateBinding Foreground}"
                                          Background="Transparent"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Padding="{TemplateBinding Padding}"/>
                        </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver"
                                            Value="True">
                                        <Setter Property="BorderBrush"
                                                Value="#6f62a2"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused"
                                            Value="True">
                                        <Setter Property="BorderBrush"
                                                Value="#c9a9ff"/>
                                        <Setter Property="Background"
                                                Value="#34303d"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AuthPasswordStyle"
                TargetType="PasswordBox">
            <Setter Property="Height"
                    Value="40"/>
            <Setter Property="Padding"
                    Value="12,8"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="Medium"/>
            <Setter Property="Background"
                    Value="#2f2f2f"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="CaretBrush"
                    Value="White"/>
            <Setter Property="BorderBrush"
                    Value="#444444"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="0"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Foreground="{TemplateBinding Foreground}"
                                          Background="Transparent"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Padding="{TemplateBinding Padding}"/>
                        </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver"
                                            Value="True">
                                        <Setter Property="BorderBrush"
                                                Value="#6f62a2"/>
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused"
                                            Value="True">
                                        <Setter Property="BorderBrush"
                                                Value="#c9a9ff"/>
                                        <Setter Property="Background"
                                                Value="#34303d"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle"
                TargetType="Button">
            <Setter Property="Height"
                    Value="38"/>
            <Setter Property="Padding"
                    Value="18,0"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="Background"
                    Value="#c9a9ff"/>
            <Setter Property="Foreground"
                    Value="#242424"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#d7bcff"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                    Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#b795f6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                    Value="False">
                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle"
                TargetType="Button"
                BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Height"
                    Value="30"/>
            <Setter Property="Padding"
                    Value="10,0"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="Foreground"
                    Value="#c9a9ff"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#2d2935"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                    Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#24212b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#212121">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                Width="420"
                Padding="34,28"
                Background="#252525"
                BorderBrush="#333333"
                BorderThickness="1"
                CornerRadius="8"
                HorizontalAlignment="Center">
            <StackPanel>
                <Grid Margin="0,0,0,24">
                    <Button Name="BackButton"
                            Click="BackButton_Click"
                            Style="{StaticResource GhostButtonStyle}"
                            HorizontalAlignment="Left"
                            ToolTip="Back to sign in">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72B;"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="13"
                                    Margin="0,0,6,0"/>
                            <TextBlock Text="Back"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="DEEZFILES"
                               FontFamily="Segoe UI"
                               FontSize="34"
                               Foreground="White"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                </Grid>

                <TextBlock Text="Email"
                        FontSize="13"
                        Foreground="#d8d8d8"
                        Margin="2,0,0,6"/>
                <TextBox x:Name="Email"
                        Style="{StaticResource AuthInputStyle}"
                        TextChanged="Email_TextChanged"/>
                <TextBlock x:Name="EmailError"
                        Foreground="#ff9090"
                        Margin="2,5,0,10"
                        FontSize="12"
                        FontWeight="Medium"/>

                <TextBlock Text="Username"
                        FontSize="13"
                        Foreground="#d8d8d8"
                        Margin="2,0,0,6"/>
                <TextBox x:Name="Username"
                        Style="{StaticResource AuthInputStyle}"
                        TextChanged="Username_TextChanged"/>
                <TextBlock x:Name="UsernameError"
                        Foreground="#ff9090"
                        Margin="2,5,0,10"
                        FontSize="12"
                        FontWeight="Medium"/>

                <TextBlock Text="Password"
                        FontSize="13"
                        Foreground="#d8d8d8"
                        Margin="2,0,0,6"/>
                <PasswordBox x:Name="Password"
                        Style="{StaticResource AuthPasswordStyle}"
                        PasswordChanged="Password_PasswordChanged"/>
                <TextBlock x:Name="PasswordError"
                        Foreground="#ff9090"
                        Margin="2,5,0,10"
                        FontSize="12"
                        FontWeight="Medium"/>

                <TextBlock Text="Confirm password"
                        FontSize="13"
                        Foreground="#d8d8d8"
                        Margin="2,0,0,6"/>
                <PasswordBox x:Name="ConfirmPassword"
                        Style="{StaticResource AuthPasswordStyle}"
                        PasswordChanged="ConfirmPassword_PasswordChanged"/>
                <TextBlock x:Name="ConfirmPasswordError"
                        Foreground="#ff9090"
                        Margin="2,5,0,18"
                        FontSize="12"
                        FontWeight="Medium"/>

                <Button Name="RegButton"
                        Click="RegButton_Click"
                        Content="Create account"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
