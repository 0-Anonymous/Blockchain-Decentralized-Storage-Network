<Page x:Class="DeezFiles.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="LoginPage"
      Background="#212121"
      UseLayoutRounding="True"
      TextOptions.TextFormattingMode="Display">

    <Page.Resources>
        <Style x:Key="AuthInputStyle"
               TargetType="TextBox">
            <Setter Property="Height"
                    Value="40"/>
            <Setter Property="Padding"
                    Value="12,8"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="Medium"/>
            <Setter Property="Background"
                    Value="#2f2f2f"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="CaretBrush"
                    Value="White"/>
            <Setter Property="SelectionBrush"
                    Value="#c9a9ff"/>
            <Setter Property="BorderBrush"
                    Value="#444444"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="0"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Foreground="{TemplateBinding Foreground}"
                                          Background="Transparent"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Padding="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="BorderBrush"
                                        Value="#6f62a2"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused"
                                     Value="True">
                                <Setter Property="BorderBrush"
                                        Value="#c9a9ff"/>
                                <Setter Property="Background"
                                        Value="#34303d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AuthPasswordStyle"
               TargetType="PasswordBox">
            <Setter Property="Height"
                    Value="40"/>
            <Setter Property="Padding"
                    Value="12,8"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="Medium"/>
            <Setter Property="Background"
                    Value="#2f2f2f"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="CaretBrush"
                    Value="White"/>
            <Setter Property="BorderBrush"
                    Value="#444444"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="0"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Foreground="{TemplateBinding Foreground}"
                                          Background="Transparent"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Padding="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter Property="BorderBrush"
                                        Value="#6f62a2"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused"
                                     Value="True">
                                <Setter Property="BorderBrush"
                                        Value="#c9a9ff"/>
                                <Setter Property="Background"
                                        Value="#34303d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle"
               TargetType="Button">
            <Setter Property="Height"
                    Value="38"/>
            <Setter Property="Padding"
                    Value="18,0"/>
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="FontWeight"
                    Value="Bold"/>
            <Setter Property="Background"
                    Value="#c9a9ff"/>
            <Setter Property="Foreground"
                    Value="#242424"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#d7bcff"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#b795f6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background"
                    Value="#2a2a2a"/>
            <Setter Property="Foreground"
                    Value="#c9a9ff"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#c9a9ff"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#342b43"/>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#262032"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#212121">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                Width="380"
                MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                Padding="34,32"
                Background="#252525"
                BorderBrush="#333333"
                BorderThickness="1"
                CornerRadius="8"
                HorizontalAlignment="Center">
            <StackPanel>
                <TextBlock Text="DEEZFILES"
                           FontFamily="Segoe UI"
                           FontSize="36"
                           Foreground="White"
                           FontWeight="Bold"
                           Margin="0,0,0,30"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Username"
                           FontSize="13"
                           Foreground="#d8d8d8"
                           Margin="2,0,0,6"/>
                <TextBox x:Name="Username"
                         Style="{StaticResource AuthInputStyle}"
                         Margin="0,0,0,16"/>

                <TextBlock Text="Password"
                           FontSize="13"
                           Foreground="#d8d8d8"
                           Margin="2,0,0,6"/>
                <PasswordBox x:Name="Password"
                             Style="{StaticResource AuthPasswordStyle}"
                             Margin="0,0,0,10"/>

                <TextBlock x:Name="LoginError"
                           Foreground="#ff9090"
                           Margin="0,0,0,16"
                           FontSize="13"
                           FontWeight="Medium"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"/>

                <Button Name="LoginButton"
                        Click="LoginButton_Click"
                        Content="Sign in"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Margin="0,0,0,20"/>

                <TextBlock Text="New to DeezFiles?"
                           FontSize="12"
                           Foreground="#8f8f8f"
                           Margin="0,0,0,8"
                           HorizontalAlignment="Center"/>

                <Button Name="RegButton"
                        Click="RegButton_Click"
                        Content="Create account"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
